generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id             String      @id
  type           String      @default("claude-runner")
  trigger        String      @default("manual")
  status         String
  startedAt      BigInt
  finishedAt     BigInt?
  log            String      @default("")
  analysisResult Json?
  issues         JobIssue[]
  results        JobResult[]
  reviews        PrReview[]
}

model JobIssue {
  id      Int    @id @default(autoincrement())
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   String
  key     String
  summary String
}

model JobResult {
  id       Int     @id @default(autoincrement())
  job      Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId    String
  issueKey String
  output   String?
  error    String?
  prUrl    String?
}

model PrReview {
  id             Int      @id @default(autoincrement())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  repoLabel      String
  prNumber       Int
  prTitle        String
  prAuthor       String
  commitSha      String
  blockers       Int      @default(0)
  majors         Int      @default(0)
  minors         Int      @default(0)
  suggestions    Int      @default(0)
  summaryComment String?
  reviewedAt     DateTime @default(now())

  @@unique([repoLabel, prNumber, commitSha])
}

model PrReviewComment {
  id        String   @id @default(cuid())
  prUrl     String
  prNumber  Int
  repo      String
  commentId Int
  author    String
  body      String
  type      String
  path      String?
  line      Int?
  status    String   @default("unread")
  fixCommit String?
  createdAt DateTime
  fetchedAt DateTime @default(now())

  @@unique([type, commentId])
}

model Repo {
  id         String  @id @default(cuid())
  name       String
  githubRepo String
  label      String  @unique
  path       String
}

model AppSetting {
  key   String @id
  value String
}
